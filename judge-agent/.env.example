# MaaS-Router Judge Agent Environment Variables

# Application Configuration
JUDGE_CONFIG_PATH=config.yaml
APP_DEBUG=false

# Judge Model Configuration
JUDGE_MODEL_API_URL=http://localhost:8001/v1/chat/completions
JUDGE_MODEL_API_KEY=your-api-key-here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Server Configuration
HOST=0.0.0.0
PORT=8000
