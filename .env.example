# MaaS-Router 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=maas
DB_PASSWORD=your-secure-password-here
DB_NAME=maas_router

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=your-redis-password-here

# JWT (至少32字符)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# CORS (逗号分隔)
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Judge Agent
JUDGE_AGENT_ADDR=http://localhost:8001

# 可选：支付集成
STRIPE_SECRET_KEY=
ALIPAY_PRIVATE_KEY=
WECHAT_PAY_SECRET=
