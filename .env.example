# ============================================================
# MaaS-Router Environment Variables
# 复制此文件为 .env 并修改实际值
#   cp .env.example .env
# ============================================================

# ── 环境 ──────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ── 数据库 ────────────────────────────────────────────
DB_NAME=maas_router
DB_USER=maas
# ⚠️  生产环境务必更换为强密码！
DB_PASSWORD=change-me-to-strong-password

# ── Redis ─────────────────────────────────────────────
# 生产环境建议设置密码
REDIS_PASSWORD=

# ── 安全（生产环境务必更换！） ────────────────────────
# 生成方式: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-random-64-char-string

# ── CORS ──────────────────────────────────────────────
# 生产环境只允许自己的域名
# 多个域名用逗号分隔
CORS_ORIGINS=https://api.your-domain.com,https://admin.your-domain.com

# ── API Key ───────────────────────────────────────────
API_KEY_PREFIX=sk-mr-

# ── 容器 Registry ─────────────────────────────────────
REGISTRY=ghcr.io
REPO=your-org/maas-router
VERSION_TAG=latest

# ── 部署目标 ──────────────────────────────────────────
STAGING_URL=https://staging.maas-router.example.com
PRODUCTION_URL=https://api.maas-router.example.com

# ── 自动部署控制 ──────────────────────────────────────
# 设为 true 则在 push main 时自动部署到生产（危险！建议保持 false）
AUTO_DEPLOY_PROD=false
